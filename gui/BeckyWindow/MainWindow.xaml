<Window x:Class="BeckyWindow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="becky" Height="760" Width="1000"
        Background="#0B0B0F" WindowStartupLocation="CenterScreen">

    <!-- High-contrast, large text (ACCESSIBILITY.md: color is an aid, keep it). -->
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Background" Value="#1E1E2A" />
            <Setter Property="BorderBrush" Value="#3A3A4D" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <DockPanel Margin="14">

        <!-- Top bar: pick a file -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <Button x:Name="BrowseButton" Content="Pick file..." DockPanel.Dock="Left"
                    Click="BrowseButton_Click" />
            <TextBlock x:Name="FileLabel" Text="No file selected" Foreground="#9AE6B4"
                       FontSize="18" VerticalAlignment="Center" Margin="14,0,0,0"
                       TextTrimming="CharacterEllipsis" />
        </DockPanel>

        <!-- Result headline + output (bottom) -->
        <TextBlock x:Name="HeadlineLabel" DockPanel.Dock="Bottom" Text="Pick a file, then click a tool."
                   Foreground="#FFD166" FontSize="20" FontWeight="Bold" TextWrapping="Wrap"
                   Margin="0,12,0,0" />
        <TextBox x:Name="OutputBox" DockPanel.Dock="Bottom" Height="250" Margin="0,8,0,0"
                 IsReadOnly="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                 FontFamily="Consolas" FontSize="15" Foreground="#E6E6F0"
                 Background="#15151D" BorderBrush="#3A3A4D" />

        <!-- Tool buttons (fill the middle) -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <WrapPanel x:Name="ToolPanel" />
        </ScrollViewer>

    </DockPanel>
</Window>
