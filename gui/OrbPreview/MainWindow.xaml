<Window x:Class="OrbPreview.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:orb="clr-namespace:Whoretana.Orb"
        Title="OrbPreview - WHORETANA orb dev harness"
        Width="1000" Height="760" Background="#0A0F14"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="280" />
        </Grid.ColumnDefinitions>

        <orb:OrbControl x:Name="Orb" Grid.Column="0" Margin="8" />
        <TextBlock x:Name="FpsText" Grid.Column="0" Text="-- fps" Foreground="#8CF6FF"
                   FontFamily="Consolas" FontSize="16" Margin="16,12,0,0"
                   HorizontalAlignment="Left" VerticalAlignment="Top" />
        <TextBlock x:Name="ScriptText" Grid.Column="0" Text="" Foreground="#3CFFC8"
                   FontFamily="Consolas" FontSize="13" Margin="16,36,0,0"
                   HorizontalAlignment="Left" VerticalAlignment="Top" />

        <StackPanel Grid.Column="1" Margin="12,16,16,16">
            <StackPanel.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="#9AB8C4" />
                    <Setter Property="FontFamily" Value="Consolas" />
                    <Setter Property="Margin" Value="0,8,0,2" />
                </Style>
                <Style TargetType="Slider">
                    <Setter Property="Minimum" Value="0" />
                    <Setter Property="Maximum" Value="1" />
                    <Setter Property="SmallChange" Value="0.05" />
                </Style>
            </StackPanel.Resources>

            <TextBlock Text="mode" />
            <ComboBox x:Name="ModeBox" SelectedIndex="0" SelectionChanged="ModeChanged">
                <ComboBoxItem Content="Idle" />
                <ComboBoxItem Content="Listening" />
                <ComboBoxItem Content="Thinking" />
                <ComboBoxItem Content="Speaking" />
            </ComboBox>

            <TextBlock Text="mic level" />
            <Slider x:Name="MicS" ValueChanged="LevelChanged" />
            <TextBlock Text="speech level" />
            <Slider x:Name="SpeechS" ValueChanged="LevelChanged" />

            <TextBlock Text="jaw" />
            <Slider x:Name="JawS" ValueChanged="VisemeChanged" />
            <TextBlock Text="funnel" />
            <Slider x:Name="FunnelS" ValueChanged="VisemeChanged" />
            <TextBlock Text="pucker" />
            <Slider x:Name="PuckerS" ValueChanged="VisemeChanged" />
            <TextBlock Text="smile" />
            <Slider x:Name="SmileS" ValueChanged="VisemeChanged" />

            <Button x:Name="EyeBtn" Content="Eye Reveal (1.2 s)" Margin="0,16,0,0" Padding="6"
                    Click="EyeClicked" />
            <Button x:Name="DemoBtn" Content="Run 20 s demo script" Margin="0,8,0,0" Padding="6"
                    Click="DemoClicked" />
        </StackPanel>
    </Grid>
</Window>
