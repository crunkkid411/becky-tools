{
  "version": 1,
  "voice": "default",
  "entries": [
    { "id": "ack.generic", "lines": ["Okay.", "On it.", "You got it.", "Yep.", "Done deal.", "Say less."] },
    { "id": "wake.ack", "lines": ["Yeah?", "What's up.", "Listening.", "Right here.", "Go."] },
    { "id": "brain.warming", "lines": ["Give me a sec, waking the big brain.", "Hang on, spinning up the heavy artillery.", "Hold up, the big brain's still booting."] },
    { "id": "confirm.needed", "lines": ["That one needs a yes from you.", "Not without your say-so.", "Need a green light before I touch that.", "You gotta sign off on that one."] },
    { "id": "special.greeting", "special": true, "lines": ["Hey. I'm here.", "Well hello."] },

    { "id": "tool.becky-transcribe.ok", "match": {"tool": "becky-transcribe", "outcome": "ok"},
      "lines": ["Transcript's done.", "Speech is text now.", "Wrote it all down.", "Every word, timestamped."] },
    { "id": "tool.becky-transcribe.partial", "match": {"tool": "becky-transcribe", "outcome": "partial"},
      "lines": ["Got most of it. Some chunks were mud.", "Transcript's in, but a few bits were garbage audio.", "Mostly transcribed. The mumbly parts fought back."] },
    { "id": "tool.becky-transcribe.error", "match": {"tool": "becky-transcribe", "outcome": "error"},
      "lines": ["FUCK. Transcribe fell over: {short}", "Transcribe choked. {short}", "No transcript. It died on me: {short}"] },

    { "id": "tool.becky-diarize.ok", "match": {"tool": "becky-diarize", "outcome": "ok"},
      "lines": ["Speakers counted and stamped.", "Split the voices out.", "I know who talked when now."] },
    { "id": "tool.becky-diarize.partial", "match": {"tool": "becky-diarize", "outcome": "partial"},
      "lines": ["Split most of the voices. A couple blur together.", "Speaker map's rough in spots but usable.", "Diarized it, mostly. Overlapping talkers are messy."] },
    { "id": "tool.becky-diarize.error", "match": {"tool": "becky-diarize", "outcome": "error"},
      "lines": ["FUCK. Diarize ate it: {short}", "Couldn't split the speakers. {short}", "Diarize crashed out: {short}"] },

    { "id": "tool.becky-identify.ok", "match": {"tool": "becky-identify", "outcome": "ok"},
      "lines": ["Matched your people.", "Faces and voices tagged.", "IDs are in."] },
    { "id": "tool.becky-identify.partial", "match": {"tool": "becky-identify", "outcome": "partial"},
      "lines": ["Tagged some of them. The rest didn't match clean.", "Partial IDs. A few faces stayed strangers.", "Got hits on some, blanks on others."] },
    { "id": "tool.becky-identify.error", "match": {"tool": "becky-identify", "outcome": "error"},
      "lines": ["FUCK. Identify broke: {short}", "No IDs. It fell over: {short}", "Identify tanked. {short}"] },

    { "id": "tool.becky-validate.ok", "match": {"tool": "becky-validate", "outcome": "ok"},
      "lines": ["Described what's on screen.", "Action rundown's ready.", "Wrote up what happens."] },
    { "id": "tool.becky-validate.partial", "match": {"tool": "becky-validate", "outcome": "partial"},
      "lines": ["Described most of it. Some scenes were murky.", "Partial rundown. A few segments beat me.", "Got the gist down, not every frame."] },
    { "id": "tool.becky-validate.error", "match": {"tool": "becky-validate", "outcome": "error"},
      "lines": ["FUCK. Validate died: {short}", "Couldn't describe it. {short}", "Validate fell on its face: {short}"] },

    { "id": "tool.becky-events.ok", "match": {"tool": "becky-events", "outcome": "ok"},
      "lines": ["Flagged the notable bits.", "Moments are marked.", "Timeline's got its highlights."] },
    { "id": "tool.becky-events.partial", "match": {"tool": "becky-events", "outcome": "partial"},
      "lines": ["Found some moments. Might've missed the quiet ones.", "Partial event pass. Take it with salt.", "Marked what stood out. Not everything did."] },
    { "id": "tool.becky-events.error", "match": {"tool": "becky-events", "outcome": "error"},
      "lines": ["FUCK. Events crashed: {short}", "No events for you. It broke: {short}", "The events pass face-planted. {short}"] },

    { "id": "tool.becky-osint.ok", "match": {"tool": "becky-osint", "outcome": "ok"},
      "lines": ["OSINT signals pulled.", "Grabbed the on-screen intel.", "Signals bagged and tagged."] },
    { "id": "tool.becky-osint.partial", "match": {"tool": "becky-osint", "outcome": "partial"},
      "lines": ["Some signals in. The blurry frames kept their secrets.", "Partial OSINT haul.", "Got a few identifiers, not the whole picture."] },
    { "id": "tool.becky-osint.error", "match": {"tool": "becky-osint", "outcome": "error"},
      "lines": ["FUCK. The OSINT run broke: {short}", "Intel grab failed. {short}", "OSINT fell over: {short}"] },

    { "id": "tool.becky-ocr.ok", "match": {"tool": "becky-ocr", "outcome": "ok"},
      "lines": ["Read all the text on screen.", "OCR's done.", "Every sign and caption, captured."] },
    { "id": "tool.becky-ocr.partial", "match": {"tool": "becky-ocr", "outcome": "partial"},
      "lines": ["Read most of the text. Some was too blurry.", "OCR got the big stuff, dropped the fine print.", "Partial read. Bad fonts fought dirty."] },
    { "id": "tool.becky-ocr.error", "match": {"tool": "becky-ocr", "outcome": "error"},
      "lines": ["FUCK. OCR choked: {short}", "Couldn't read the screen. {short}", "OCR crashed: {short}"] },

    { "id": "tool.becky-framematch.ok", "match": {"tool": "becky-framematch", "outcome": "ok"},
      "lines": ["Frame pairs matched.", "Found your matching shots.", "Comparison exhibit's ready."] },
    { "id": "tool.becky-framematch.partial", "match": {"tool": "becky-framematch", "outcome": "partial"},
      "lines": ["Matched some frames. Others are a maybe.", "Partial matches. Eyeball them yourself.", "A few solid pairs, the rest is thin."] },
    { "id": "tool.becky-framematch.error", "match": {"tool": "becky-framematch", "outcome": "error"},
      "lines": ["FUCK. Framematch broke: {short}", "No pairs. It died: {short}", "Framematch face-planted: {short}"] },

    { "id": "tool.becky-cut.ok", "match": {"tool": "becky-cut", "outcome": "ok"},
      "lines": ["Dead air's gone.", "Cut the silence out.", "Trimmed and tight."] },
    { "id": "tool.becky-cut.partial", "match": {"tool": "becky-cut", "outcome": "partial"},
      "lines": ["Cut most of the dead air. Left the ambiguous bits.", "Partial trim. Some silence survived.", "Cut what I was sure about."] },
    { "id": "tool.becky-cut.error", "match": {"tool": "becky-cut", "outcome": "error"},
      "lines": ["FUCK. The cut broke: {short}", "Cutting failed. {short}", "Cut fell over mid-edit: {short}"] },

    { "id": "tool.becky-pipeline.ok", "match": {"tool": "becky-pipeline", "outcome": "ok"},
      "lines": ["Full pass, done. Everything's in.", "Pipeline finished end to end.", "Ran the whole gauntlet. It's all there."] },
    { "id": "tool.becky-pipeline.partial", "match": {"tool": "becky-pipeline", "outcome": "partial"},
      "lines": ["Pipeline mostly ran. A step or two limped.", "Most steps landed. Check the stragglers.", "Partial pipeline. It's resumable, so just say go."] },
    { "id": "tool.becky-pipeline.error", "match": {"tool": "becky-pipeline", "outcome": "error"},
      "lines": ["FUCK. The pipeline blew up: {short}", "Pipeline stalled out. {short}", "The full pass died mid-run: {short}"] },

    { "id": "tool.becky-search.ok", "match": {"tool": "becky-search", "outcome": "ok"},
      "lines": ["Search results are up.", "Found your matches.", "Dug through the corpus. Hits are in."] },
    { "id": "tool.becky-search.partial", "match": {"tool": "becky-search", "outcome": "partial"},
      "lines": ["Some hits. Nothing great.", "Found a few weak matches.", "Search came back thin."] },
    { "id": "tool.becky-search.error", "match": {"tool": "becky-search", "outcome": "error"},
      "lines": ["FUCK. Search broke: {short}", "Search crashed out. {short}", "No results. It died: {short}"] },

    { "id": "tool.becky-review.ok", "match": {"tool": "becky-review", "outcome": "ok"},
      "lines": ["Review's written.", "Summarized the findings.", "The think-piece is done."] },
    { "id": "tool.becky-review.partial", "match": {"tool": "becky-review", "outcome": "partial"},
      "lines": ["Reviewed what I could. Some findings were thin.", "Partial review. The gaps are flagged.", "Half a review. The data ran out."] },
    { "id": "tool.becky-review.error", "match": {"tool": "becky-review", "outcome": "error"},
      "lines": ["FUCK. Review fell over: {short}", "The LLM step choked. {short}", "Review died: {short}"] },

    { "id": "tool.becky-research.ok", "match": {"tool": "becky-research", "outcome": "ok"},
      "lines": ["Research's done. Citations and all.", "Dug deep. The report's ready.", "Ran the research gauntlet. It's in."] },
    { "id": "tool.becky-research.partial", "match": {"tool": "becky-research", "outcome": "partial"},
      "lines": ["Some answers, some dead ends.", "Partial research. The sources were shaky.", "Got half the picture. The rest needs another pass."] },
    { "id": "tool.becky-research.error", "match": {"tool": "becky-research", "outcome": "error"},
      "lines": ["FUCK. Research bombed: {short}", "The research run crashed: {short}", "Couldn't finish the dig. {short}"] },

    { "id": "tool.becky-radar.ok", "match": {"tool": "becky-radar", "outcome": "ok"},
      "lines": ["Radar swept. Report's in.", "Checked your history for new toys.", "Radar's done. Flagged what matters."] },
    { "id": "tool.becky-radar.partial", "match": {"tool": "becky-radar", "outcome": "partial"},
      "lines": ["Radar swept part of it.", "Partial sweep. History access was flaky.", "Some blips flagged, the rest unread."] },
    { "id": "tool.becky-radar.error", "match": {"tool": "becky-radar", "outcome": "error"},
      "lines": ["FUCK. Radar died: {short}", "The radar sweep broke: {short}", "No sweep. It crashed: {short}"] },

    { "id": "tool.becky-scout.ok", "match": {"tool": "becky-scout", "outcome": "ok"},
      "lines": ["Scouted the playlist.", "Watched them all. Notes are in.", "Scout report's ready."] },
    { "id": "tool.becky-scout.partial", "match": {"tool": "becky-scout", "outcome": "partial"},
      "lines": ["Scouted some videos. A few wouldn't load.", "Partial scout. YouTube fought back.", "Half the playlist assessed."] },
    { "id": "tool.becky-scout.error", "match": {"tool": "becky-scout", "outcome": "error"},
      "lines": ["FUCK. Scout fell over: {short}", "Scouting broke: {short}", "The scout run died: {short}"] },

    { "id": "tool.becky-web2md.ok", "match": {"tool": "becky-web2md", "outcome": "ok"},
      "lines": ["Page saved as markdown.", "Clipped it clean.", "That page is in the wiki now."] },
    { "id": "tool.becky-web2md.partial", "match": {"tool": "becky-web2md", "outcome": "partial"},
      "lines": ["Saved the page, mostly. Some junk got through.", "The clip's in but a bit ragged.", "Partial grab. The layout was hostile."] },
    { "id": "tool.becky-web2md.error", "match": {"tool": "becky-web2md", "outcome": "error"},
      "lines": ["FUCK. Web2md choked: {short}", "Couldn't grab the page. {short}", "The page grab died: {short}"] },

    { "id": "tool.becky-clipcheck.ok", "match": {"tool": "becky-clipcheck", "outcome": "ok"},
      "lines": ["Clip checks out.", "Verified. The page is really in there.", "The clip's legit."] },
    { "id": "tool.becky-clipcheck.partial", "match": {"tool": "becky-clipcheck", "outcome": "partial"},
      "lines": ["The clip's borderline. Most of the page is there.", "Partial verification. Some sections are iffy.", "It half checks out."] },
    { "id": "tool.becky-clipcheck.error", "match": {"tool": "becky-clipcheck", "outcome": "error"},
      "lines": ["FUCK. Clipcheck broke: {short}", "Couldn't verify the clip. {short}", "Clipcheck died: {short}"] },

    { "id": "tool.becky-regrab.ok", "match": {"tool": "becky-regrab", "outcome": "ok"},
      "lines": ["Re-grabbed the page. Got it this time.", "Recovery worked. The page is saved.", "Second try landed."] },
    { "id": "tool.becky-regrab.partial", "match": {"tool": "becky-regrab", "outcome": "partial"},
      "lines": ["The re-grab got most of it.", "Recovered part of the page.", "Partial recovery. Better than nothing."] },
    { "id": "tool.becky-regrab.error", "match": {"tool": "becky-regrab", "outcome": "error"},
      "lines": ["FUCK. The regrab failed too: {short}", "Still can't get that page. {short}", "Regrab died: {short}"] },

    { "id": "tool.becky-export.ok", "match": {"tool": "becky-export", "outcome": "ok"},
      "lines": ["Package is exported.", "Bundled and ready to share.", "Export's done."] },
    { "id": "tool.becky-export.partial", "match": {"tool": "becky-export", "outcome": "partial"},
      "lines": ["Exported most of it. A few pieces didn't bundle.", "Partial package. Check it before you send it.", "Export's in, minus some stragglers."] },
    { "id": "tool.becky-export.error", "match": {"tool": "becky-export", "outcome": "error"},
      "lines": ["FUCK. Export blew up: {short}", "Export failed. {short}", "Couldn't build the package: {short}"] },

    { "id": "tool.reaper-bridge.ok", "match": {"tool": "reaper-bridge", "outcome": "ok"},
      "lines": ["REAPER's updated.", "The takes are in the session.", "Arrangement's done."] },
    { "id": "tool.reaper-bridge.partial", "match": {"tool": "reaper-bridge", "outcome": "partial"},
      "lines": ["Pushed some edits. REAPER argued about the rest.", "Partial session update.", "Half the edits landed."] },
    { "id": "tool.reaper-bridge.error", "match": {"tool": "reaper-bridge", "outcome": "error"},
      "lines": ["FUCK. The REAPER bridge broke: {short}", "Session edit failed. {short}", "REAPER said no: {short}"] },

    { "id": "tool.becky-imagegen.ok", "match": {"tool": "becky-imagegen", "outcome": "ok"},
      "lines": ["Image is baked.", "Picture's done. Fully local, baby.", "Rendered your image."] },
    { "id": "tool.becky-imagegen.partial", "match": {"tool": "becky-imagegen", "outcome": "partial"},
      "lines": ["Generated something. Not sure it's what you meant.", "Image is in, quality's debatable.", "Partial gen. It's a bit cursed."] },
    { "id": "tool.becky-imagegen.error", "match": {"tool": "becky-imagegen", "outcome": "error"},
      "lines": ["FUCK. Imagegen died: {short}", "No image. It crashed: {short}", "The GPU said no: {short}"] },

    { "id": "tool.enroll-wiki.ok", "match": {"tool": "enroll-wiki", "outcome": "ok"},
      "lines": ["KB's built. Everyone's enrolled.", "Learned your people from the wiki.", "Knowledge base is stocked."] },
    { "id": "tool.enroll-wiki.partial", "match": {"tool": "enroll-wiki", "outcome": "partial"},
      "lines": ["Enrolled most of them. A few had no usable clips.", "Partial enrollment.", "Some people made it in, some didn't."] },
    { "id": "tool.enroll-wiki.error", "match": {"tool": "enroll-wiki", "outcome": "error"},
      "lines": ["FUCK. Enrollment broke: {short}", "The KB build died: {short}", "Enroll-wiki fell over: {short}"] },

    { "id": "tool.index.ok", "match": {"tool": "index", "outcome": "ok"},
      "lines": ["Corpus indexed. Search away.", "Everything's embedded and searchable.", "Index is built."] },
    { "id": "tool.index.partial", "match": {"tool": "index", "outcome": "partial"},
      "lines": ["Indexed most of the folder. Some files fought.", "Partial index. A few videos got skipped.", "Mostly indexed."] },
    { "id": "tool.index.error", "match": {"tool": "index", "outcome": "error"},
      "lines": ["FUCK. Indexing died: {short}", "The index run broke: {short}", "Couldn't index the folder: {short}"] },

    { "id": "tool.profile.ok", "match": {"tool": "profile", "outcome": "ok"},
      "lines": ["Profile card's ready.", "Dossier's done.", "Got their whole story on one card."] },
    { "id": "tool.profile.partial", "match": {"tool": "profile", "outcome": "partial"},
      "lines": ["Thin profile. Not much in the corpus on them.", "Partial dossier.", "Some of their story, not all of it."] },
    { "id": "tool.profile.error", "match": {"tool": "profile", "outcome": "error"},
      "lines": ["FUCK. Profile broke: {short}", "Couldn't build the card. {short}", "Profile died: {short}"] },

    { "id": "tool.appearances.ok", "match": {"tool": "appearances", "outcome": "ok"},
      "lines": ["Found every video they're in.", "Appearance list's ready.", "Tracked them across the corpus."] },
    { "id": "tool.appearances.partial", "match": {"tool": "appearances", "outcome": "partial"},
      "lines": ["Found some appearances. There might be more hiding.", "Partial hit list.", "A few sightings. The corpus is big."] },
    { "id": "tool.appearances.error", "match": {"tool": "appearances", "outcome": "error"},
      "lines": ["FUCK. Appearances broke: {short}", "Couldn't track them: {short}", "The appearance search died: {short}"] },

    { "id": "tool.find.ok", "match": {"tool": "find", "outcome": "ok"},
      "lines": ["Found it. Timestamps and all.", "Hits are up.", "There it is."] },
    { "id": "tool.find.partial", "match": {"tool": "find", "outcome": "partial"},
      "lines": ["Found a few weak hits.", "Partial matches. Nothing solid.", "Some mentions, low confidence."] },
    { "id": "tool.find.error", "match": {"tool": "find", "outcome": "error"},
      "lines": ["FUCK. Find broke: {short}", "The search fell over: {short}", "Find died on me: {short}"] },

    { "id": "tool.corroborate.ok", "match": {"tool": "corroborate", "outcome": "ok"},
      "lines": ["Pulled the supporting moments.", "Cross-referenced. The evidence is lined up.", "Receipts are in."] },
    { "id": "tool.corroborate.partial", "match": {"tool": "corroborate", "outcome": "partial"},
      "lines": ["Some support found. It's not airtight.", "Partial corroboration.", "A few supporting clips, thin ice elsewhere."] },
    { "id": "tool.corroborate.error", "match": {"tool": "corroborate", "outcome": "error"},
      "lines": ["FUCK. Corroborate broke: {short}", "The cross-reference died: {short}", "Couldn't pull the receipts: {short}"] },

    { "id": "tool.this-is-name.ok", "match": {"tool": "this is <name>", "outcome": "ok"},
      "lines": ["Got it. They're in the KB now.", "Learned them.", "New face, filed."] },
    { "id": "tool.this-is-name.partial", "match": {"tool": "this is <name>", "outcome": "partial"},
      "lines": ["Enrolled them, but the clip was rough.", "They're in, barely. Get me a cleaner clip.", "Partial enrollment. The voice took, the face didn't."] },
    { "id": "tool.this-is-name.error", "match": {"tool": "this is <name>", "outcome": "error"},
      "lines": ["FUCK. Couldn't learn them: {short}", "Enrollment broke: {short}", "That clip beat me: {short}"] },

    { "id": "tool.screenshot.ok", "match": {"tool": "screenshot", "outcome": "ok"},
      "lines": ["Got the screen.", "Snapped it.", "Screenshot's in."] },
    { "id": "tool.screenshot.partial", "match": {"tool": "screenshot", "outcome": "partial"},
      "lines": ["Grabbed part of the screen.", "Screenshot's in but something looks off.", "Got a shot. Might be stale."] },
    { "id": "tool.screenshot.error", "match": {"tool": "screenshot", "outcome": "error"},
      "lines": ["FUCK. Screenshot failed: {short}", "Couldn't grab the screen: {short}", "Screen capture died: {short}"] },

    { "id": "tool.desktop_click.ok", "match": {"tool": "desktop_click", "outcome": "ok"},
      "lines": ["Clicked.", "Click landed.", "Done. Clicked it."] },
    { "id": "tool.desktop_click.partial", "match": {"tool": "desktop_click", "outcome": "partial"},
      "lines": ["Clicked, but I'm not sure it took.", "The click went out. The screen didn't react much.", "Clicked something. Verify me."] },
    { "id": "tool.desktop_click.error", "match": {"tool": "desktop_click", "outcome": "error"},
      "lines": ["FUCK! The mouse is broken again: {short}", "Click failed: {short}", "Couldn't click that: {short}"] },

    { "id": "tool.desktop_type.ok", "match": {"tool": "desktop_type", "outcome": "ok"},
      "lines": ["Typed it.", "Text's in.", "Keyed it in."] },
    { "id": "tool.desktop_type.partial", "match": {"tool": "desktop_type", "outcome": "partial"},
      "lines": ["Typed most of it.", "The text went in. Might be missing a chunk.", "Typed it, but the focus was shaky."] },
    { "id": "tool.desktop_type.error", "match": {"tool": "desktop_type", "outcome": "error"},
      "lines": ["FUCK. The keyboard flaked: {short}", "Typing failed: {short}", "Couldn't type that: {short}"] },

    { "id": "tool.desktop_press.ok", "match": {"tool": "desktop_press", "outcome": "ok"},
      "lines": ["Pressed.", "Keys sent.", "Done. Hotkey fired."] },
    { "id": "tool.desktop_press.partial", "match": {"tool": "desktop_press", "outcome": "partial"},
      "lines": ["Sent the keys. No visible reaction.", "Pressed it. Not sure it registered.", "The keys went out. Shrug."] },
    { "id": "tool.desktop_press.error", "match": {"tool": "desktop_press", "outcome": "error"},
      "lines": ["FUCK. The key press failed: {short}", "The hotkey died: {short}", "Couldn't send the keys: {short}"] },

    { "id": "tool.desktop_move.ok", "match": {"tool": "desktop_move", "outcome": "ok"},
      "lines": ["Moved.", "Cursor's there.", "Mouse repositioned."] },
    { "id": "tool.desktop_move.partial", "match": {"tool": "desktop_move", "outcome": "partial"},
      "lines": ["Moved it, roughly.", "The cursor's close enough.", "Moved, give or take a pixel."] },
    { "id": "tool.desktop_move.error", "match": {"tool": "desktop_move", "outcome": "error"},
      "lines": ["FUCK. The mouse move failed: {short}", "The cursor wouldn't budge: {short}", "Couldn't move the mouse: {short}"] }
