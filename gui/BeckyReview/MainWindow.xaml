<Window x:Class="BeckyReview.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:wf="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        Title="Becky Review" Height="820" Width="1400"
        Background="#0B0B0F" WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <!-- High-contrast, large text (ACCESSIBILITY.md: color is an aid, keep it). -->
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Background" Value="#1E1E2A" />
            <Setter Property="BorderBrush" Value="#3A3A4D" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Foreground" Value="#E6E6F0" />
            <Setter Property="Background" Value="#15151D" />
            <Setter Property="BorderBrush" Value="#3A3A4D" />
            <Setter Property="CaretBrush" Value="#9AE6B4" />
        </Style>
    </Window.Resources>

    <DockPanel Margin="12">

        <!-- Top bar: pick folder + search -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <Button x:Name="PickFolderButton" Content="Pick folder..." DockPanel.Dock="Left"
                    Click="PickFolderButton_Click" />
            <TextBlock x:Name="StatusLabel" Text="Step 0 - empty window" DockPanel.Dock="Right"
                       Foreground="#FFD166" FontSize="16" VerticalAlignment="Center" Margin="14,0,4,0" />
            <TextBox x:Name="SearchBox" Margin="8,0,8,0" VerticalContentAlignment="Center"
                     KeyDown="SearchBox_KeyDown" />
        </DockPanel>

        <!-- Two side-by-side panes with a draggable splitter between them. -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="320" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="3*" MinWidth="360" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: WebView2 (HTML UI, virtual-host, NO server) - results / clip list. -->
            <Border Grid.Column="0" Background="#101018" BorderBrush="#3A3A4D" BorderThickness="1"
                    CornerRadius="4">
                <Grid x:Name="LeftPaneHost">
                    <wv2:WebView2 x:Name="WebView" />
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"
                          Background="#2A2A38" ResizeBehavior="PreviousAndNext" />

            <!-- RIGHT: native libmpv video pane (embedded via mpv wid into a WinForms HWND). -->
            <Border Grid.Column="2" Background="#000000" BorderBrush="#3A3A4D" BorderThickness="1"
                    CornerRadius="4">
                <Grid x:Name="RightPaneHost">
                    <wf:WindowsFormsHost x:Name="VideoHostElement" />
                    <TextBlock x:Name="VideoPlaceholder" Text="RIGHT - video preview"
                               Foreground="#6E7191" FontSize="20" HorizontalAlignment="Center"
                               VerticalAlignment="Center" IsHitTestVisible="False" />
                </Grid>
            </Border>
        </Grid>

    </DockPanel>
</Window>
