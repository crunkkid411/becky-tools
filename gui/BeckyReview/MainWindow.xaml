<Window x:Class="BeckyReview.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:wf="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        Title="Becky Review" Height="860" Width="1500"
        Background="#000000" WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <!-- High-contrast, large text (ACCESSIBILITY.md: color is an aid, keep it). -->
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Background" Value="#141414" />
            <Setter Property="BorderBrush" Value="#39FF14" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- Top bar: pick a case folder (native dialog) + status. Search/everything else is in the UI. -->
        <DockPanel DockPanel.Dock="Top" Background="#0A0A0A" LastChildFill="True">
            <Button x:Name="PickFolderButton" Content="Pick folder..." DockPanel.Dock="Left"
                    Click="PickFolderButton_Click" />
            <TextBlock x:Name="StatusLabel" Text="Pick a case folder to begin." DockPanel.Dock="Right"
                       Foreground="#FFD700" FontSize="14" VerticalAlignment="Center"
                       Margin="14,0,12,0" TextTrimming="CharacterEllipsis" />
            <TextBlock />
        </DockPanel>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" MinWidth="520" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="2*" MinWidth="420" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: the full WebView2 UI (find + quotes + timeline + chat). No server. -->
            <wv2:WebView2 x:Name="WebView" Grid.Column="0" />

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"
                          Background="#1A1A1A" ResizeBehavior="PreviousAndNext" />

            <!-- RIGHT: native libmpv video pane (the smooth, frame-exact player). -->
            <Border Grid.Column="2" Background="#000000">
                <Grid>
                    <wf:WindowsFormsHost x:Name="VideoHostElement" />
                    <TextBlock x:Name="VideoPlaceholder"
                               Text="Click a result on the left to play that moment here."
                               Foreground="#5A5A5A" FontSize="18" HorizontalAlignment="Center"
                               VerticalAlignment="Center" IsHitTestVisible="False"
                               TextWrapping="Wrap" TextAlignment="Center" Margin="20" />
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
